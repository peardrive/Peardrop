{
  "private": true,
  "name": "peardrop-mobile",
  "version": "0.1.0",
  "description": "PearDrop for Android and iOS",
  "main": "expo-router/entry",
  "scripts": {
    "setup": "npm install && npm run bundle:backend",
    "dev": "npm run bundle:backend && expo start",
    "dev:android": "npm run bundle:backend && expo run:android",
    "dev:ios": "npm run bundle:backend && expo run:ios",
    "phone:test": "node scripts/peardrop-phone-test.mjs interactive",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "bundle:backend": "bare-pack --preset mobile -o app/app.bundle.mjs backend/backend.mjs",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "test": "jest",
    "test:parity": "node test/integration/run-parity.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "b4a": "^1.7.3",
    "bare-fs": "^4.6.0",
    "bare-path": "^3.0.0",
    "bare-rpc": "^1.1.0",
    "corestore": "^7.9.2",
    "expo": "^54.0.10",
    "expo-audio": "^1.0.6",
    "expo-build-properties": "^1.0.9",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "^7.0.1",
    "expo-constants": "^18.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "^55.0.14",
    "expo-image-picker": "~17.0.11",
    "expo-intent-launcher": "~13.0.7",
    "expo-linking": "^8.0.8",
    "expo-notifications": "^55.0.20",
    "expo-router": "^6.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-system-ui": "^6.0.7",
    "expo-video": "^3.0.5",
    "expo-video-thumbnails": "^9.0.7",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-native": "^0.81.4",
    "react-native-b4a": "^0.0.4",
    "react-native-bare-kit": "^0.11.0",
    "react-native-fs": "^2.20.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.19.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.3",
    "bare": "^1.30.3",
    "bare-pack": "^1.5.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "react": "19.1.4",
    "react-dom": "19.1.4"
  }
}
